# -------------------------------------------------------
# NVR Environment Variables
# Copy this file to .env and set your values.
# The docker-compose.yml reads these automatically.
# -------------------------------------------------------

# REQUIRED: Secret key for session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
REC_SECRET_KEY=change-me-to-something-long-and-random

# Optional: Timezone for the host container (default: UTC)
TZ=America/New_York

# Optional: File paths inside the container (defaults shown)
CONFIG_PATH=/config/config.json
GO2RTC_CONFIG_PATH=/config/go2rtc.yaml
ENCRYPTION_KEY_PATH=/config/encryption.key
DB_PATH=/config/nvr.db

# Optional: go2rtc service hostname (default: go2rtc)
# Change this only if running go2rtc outside of Docker Compose.
GO2RTC_HOST=go2rtc
